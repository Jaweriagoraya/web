<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Register</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <main class="auth-wrap">
    <div class="auth-card center">
      <div class="brand">
        <div class="logo">E</div>
        <div>
          <h2>Engine Shop</h2>
          <div style="color:var(--muted);font-size:0.95rem">Join the community — orders saved & faster checkout</div>
        </div>
      </div>

      <div class="form-header">
        <h1>Create account</h1>
        <div class="form-sub">Create a free account to save orders and checkout faster.</div>
      </div>

      <% if (success && success.length) { %>
        <div class="flash-success"><%= success[0] %></div>
      <% } %>
      <% if (error && error.length) { %>
        <div class="flash-error"><%= error[0] %></div>
      <% } %>

      <form action="/register" method="POST">
        <div class="form-group">
          <label for="name">Full name</label>
          <input id="name" class="form-control" type="text" name="name" required>
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input id="email" class="form-control" type="email" name="email" required>
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input id="password" class="form-control" type="password" name="password" required>
        </div>
        <div class="form-group">
          <label for="passwordConfirm">Confirm password</label>
          <input id="passwordConfirm" class="form-control" type="password" name="passwordConfirm" required>
        </div>
        <button class="btn-primary" type="submit">Create account</button>
      </form>

      <div class="auth-footer" style="display:flex;justify-content:space-between;align-items:center;gap:12px;margin-top:18px">
        <div>Already have an account? <a class="small-link" href="/login">Sign in</a></div>
        <div><a class="small-link" href="/">Back to store</a></div>
      </div>
    </div>
  </main>
</body>
</html>
