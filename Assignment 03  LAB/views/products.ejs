<!DOCTYPE html>
<html>
<head>
    <title>Products</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <% if (success && success.length > 0) { %>
        <div class="flash-success"><%= success[0] %></div>
    <% } %>
    <% if (error && error.length > 0) { %>
        <div class="flash-error"><%= error[0] %></div>
    <% } %>

    <h1>Products</h1>

    <form method="GET" action="/products" class="product-filters">
        <input type="text" name="search" placeholder="Search Product" value="<%= search %>">

        <select name="category">
            <option value="" <%= category === "" ? "selected" : "" %>>All Categories</option>
            <option value="Men" <%= category === "Men" ? "selected" : "" %>>Men</option>
            <option value="Women" <%= category === "Women" ? "selected" : "" %>>Women</option>
            <option value="Girls" <%= category === "Girls" ? "selected" : "" %>>Girls</option>
            <option value="Home" <%= category === "Home" ? "selected" : "" %>>Home</option>
            <option value="Fashion" <%= category === "Fashion" ? "selected" : "" %>>Fashion</option>
            <option value="Electronics" <%= category === "Electronics" ? "selected" : "" %>>Electronics</option>
        </select>

        <input type="number" name="minPrice" placeholder="Min Price" value="<%= minPrice %>">
        <input type="number" name="maxPrice" placeholder="Max Price" value="<%= maxPrice %>">

        <select name="sort">
            <option value="" <%= sort === "" ? "selected" : "" %>>Sort by</option>
            <option value="price_asc" <%= sort === "price_asc" ? "selected" : "" %>>Price: Low to High</option>
            <option value="price_desc" <%= sort === "price_desc" ? "selected" : "" %>>Price: High to Low</option>
            <option value="rating_desc" <%= sort === "rating_desc" ? "selected" : "" %>>Rating: High to Low</option>
        </select>

        <button type="submit">Filter</button>
    </form>

    <p><%= totalProducts %> product<%= totalProducts === 1 ? "" : "s" %> found</p>

    <div class="products-container">
        <% if (products.length === 0) { %>
            <p>No products found.</p>
        <% } else { %>
            <% products.forEach(product => { %>
                <div class="product-card">
                    <img src="<%= product.image || '/1.avif' %>" width="200" alt="<%= product.name %>">
                    <h3><%= product.name %></h3>
                    <p>Price: Rs.<%= product.price %></p>
                    <p>Category: <%= product.category %></p>
                    <p>Rating: <%= product.rating %></p>
                    <p>Stock: <%= product.stock %></p>
                </div>
            <% }) %>
        <% } %>
    </div>

    <div class="pagination">
        <% const queryParams = `search=${encodeURIComponent(search)}&category=${encodeURIComponent(category)}&minPrice=${encodeURIComponent(minPrice)}&maxPrice=${encodeURIComponent(maxPrice)}&sort=${encodeURIComponent(sort)}`; %>

        <% if (currentPage > 1) { %>
            <a href="/products?page=<%= currentPage - 1 %>&<%= queryParams %>">Previous</a>
        <% } %>

        <% for (let i = 1; i <= totalPages; i++) { %>
            <a class="<%= i === currentPage ? 'active' : '' %>" href="/products?page=<%= i %>&<%= queryParams %>"><%= i %></a>
        <% } %>

        <% if (currentPage < totalPages) { %>
            <a href="/products?page=<%= currentPage + 1 %>&<%= queryParams %>">Next</a>
        <% } %>
    </div>

</body>
</html>
