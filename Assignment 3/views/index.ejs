<!DOCTYPE html>
<html>
<head>

<title>Engine Clone</title>

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link rel="stylesheet" href="/style.css">

</head>

<body>

<div class="top-bar">
Free delivery for order above RS.5000
</div>

<header class="navbar">
    <div class="menu-toggle" id="menu-toggle">
☰
</div>

    <ul class="nav-left">
        <li><a href="/products?sort=rating_desc">Sale</a></li>
        <li><a href="/products?sort=price_desc">New In</a></li>
        <% allCategories.forEach(category => { %>
            <% if (category.toLowerCase() !== 'home') { %>
                <li><a href="/products?category=<%= category %>"><%= category %></a></li>
            <% } %>
        <% }) %>
    </ul>

<div class="logo">
    <a href="/"><img src="New_Logo_Engine.svg"></a>
</div>

<div class="nav-right">
    <div class="nav-search">
        <input type="text" placeholder="Search...">
    </div>
    <% if (currentUser) { %>
        <a href="/profile" class="nav-link">My Profile</a>
        <a href="/logout" class="nav-link">Logout</a>
    <% } else { %>
        <a href="/login" class="nav-link">Login</a>
        <a href="/register" class="nav-link button">Register</a>
    <% } %>
        <a href="/cart" class="nav-link">Cart (<%= typeof cartItemCount !== 'undefined' ? cartItemCount : 0 %>)</a>
    </div>
</header>

<section class="hero">
    <div class="hero-text">
        <h1>Elevate Your Style</h1>
        <h2>Fresh streetwear for every season</h2>
        <p>Discover our latest collection and save up to 40% today.</p>
        <a href="/products?sort=rating_desc" class="hero-button">Shop Now</a>
    </div>
</section>


<section class="shirts-section">

<h2 class="section-title">Shirts</h2>

<div class="shirts-slider">

<div class="shirt-card">
<img src="shirt1.webp">
<p>SALE</p>
</div>

<div class="shirt-card">
<img src="shirt2.webp">
<p>Tops</p>
</div>

<div class="shirt-card">
<img src="shirt3.webp">
<p>Outwears</p>
</div>

<div class="shirt-card">
<img src="shirt4.webp">
<p>Shirts</p>
</div>

<div class="shirt-card">
<img src="shirt5.webp">
<p>Trousers</p>
</div>

<div class="shirt-card">
<img src="shirts6.webp">
<p>Pants</p>
</div>

<div class="shirt-card">
<img src="shirt7.webp">
<p>Sweat shirts</p>
</div>

</div>

</section>


<section class="promo-banner">

<div class="banner-content">

<h2>NEW SEASON ARRIVALS</h2>

<p>UP TO 40% OFF</p>

<button>SHOP NOW</button>

</div>

</section>


