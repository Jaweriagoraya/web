<!DOCTYPE html>
<html lang="en">
<head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Admin Login</title>
        <link rel="stylesheet" href="/style.css">
</head>
<body>
        <main class="auth-wrap">
            <div class="auth-card center">
                <div class="brand">
                    <div class="logo">E</div>
                    <div>
                        <h2>Engine Shop</h2>
                        <div style="color:var(--muted);font-size:0.95rem">Admin access area</div>
                    </div>
                </div>
                <div>
                    <h1>Admin <span style="color:#2563eb">Login</span></h1>
            <% if (error && error.length) { %>
                <div class="flash-error"><%= error[0] %></div>
            <% } %>
            <form action="/admin/login" method="POST">
                <div class="form-group">
                    <label for="email">Email</label>
                    <input id="email" class="form-control" name="email" type="email" required>
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input id="password" class="form-control" name="password" type="password" required>
                </div>
                <button class="btn-primary" type="submit">Sign In</button>
                        </form>
                        <p class="auth-footer">Use an admin account to access the dashboard.</p>
                </div>
            </div>
        </main>
</body>
</html>
