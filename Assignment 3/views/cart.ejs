<!DOCTYPE html>
<html>
<head>
    <title>Shopping Cart</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        .cart-container { max-width: 800px; margin: 50px auto; padding: 20px; font-family: sans-serif; }
        .cart-item { display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #ccc; padding: 15px 0; }
        .cart-item img { width: 80px; border-radius: 8px; }
        .cart-details { flex-grow: 1; margin-left: 20px; }
        .cart-actions { display: flex; align-items: center; gap: 10px; }
        .cart-actions button { padding: 5px 10px; cursor: pointer; }
        .cart-summary { text-align: right; margin-top: 30px; font-size: 1.5em; font-weight: bold; }
        .checkout-btn { display: block; width: 100%; padding: 15px; background: #000; color: #fff; text-align: center; text-decoration: none; margin-top: 20px; border-radius: 5px; font-size: 1.2em; font-weight: bold; }
        .checkout-btn:hover { background: #333; }
        .empty-cart { text-align: center; margin-top: 50px; font-size: 1.2em; }
    </style>
</head>
<body>
    <div class="top-bar">
        Free delivery for order above RS.5000
    </div>
    <header class="navbar" style="background:#fff; padding:15px; border-bottom:1px solid #eee;">
        <div class="logo">
            <a href="/" style="text-decoration:none; color:black; font-weight:bold; font-size:1.5em;">Engine Clone</a>
        </div>
        <div class="nav-right" style="display:flex; gap:15px; align-items:center;">
            <a href="/products" class="nav-link">Continue Shopping</a>
            <a href="/cart" class="nav-link" style="font-weight:bold;">Cart (<%= typeof cartItemCount !== 'undefined' ? cartItemCount : 0 %>)</a>
            <a href="/profile" class="nav-link">My Profile</a>
            <a href="/logout" class="nav-link" style="color:red; font-weight:bold;">Logout</a>
        </div>
    </header>

    <div class="cart-container">
        <h1>Your Shopping Cart</h1>

        <% if (success && success.length > 0) { %>
            <div style="background: #d4edda; color: #155724; padding: 10px; margin-bottom: 20px; border-radius: 4px;"><%= success[0] %></div>
        <% } %>

        <% if (cartItems.length === 0) { %>
            <div class="empty-cart">
                <p>Your cart is empty.</p>
                <br>
                <a href="/products" style="padding:10px 20px; background:black; color:white; text-decoration:none; border-radius: 4px;">Browse Products</a>
            </div>
        <% } else { %>
            <% cartItems.forEach(item => { %>
                <div class="cart-item">
                    <img src="<%= item.product.image %>" alt="<%= item.product.name %>">
                    <div class="cart-details">
                        <h3 style="margin: 0;"><%= item.product.name %></h3>
                        <p style="margin: 5px 0;">Rs.<%= item.product.price %></p>
                    </div>
                    <div class="cart-actions">
                        <form action="/cart/update/<%= item.product._id %>" method="POST" style="display:inline;">
                            <input type="hidden" name="action" value="decrease">
                            <button type="submit" style="background: #eee; border: 1px solid #ccc; font-weight: bold;">-</button>
                        </form>
                        <span style="font-weight: bold; width: 20px; text-align: center;"><%= item.quantity %></span>
                        <form action="/cart/update/<%= item.product._id %>" method="POST" style="display:inline;">
                            <input type="hidden" name="action" value="increase">
                            <button type="submit" style="background: #eee; border: 1px solid #ccc; font-weight: bold;">+</button>
                        </form>
                        <form action="/cart/remove/<%= item.product._id %>" method="POST" style="display:inline; margin-left: 15px;">
                            <button type="submit" style="background:red; color:white; border:none; border-radius:3px; cursor: pointer;">Remove</button>
                        </form>
                    </div>
                    <div style="font-weight:bold; min-width: 100px; text-align:right;">
                        Rs.<%= item.subtotal %>
                    </div>
                </div>
            <% }) %>

            <div class="cart-summary">
                Total: Rs.<%= cartTotal %>
            </div>
            
            <a href="#" class="checkout-btn">Proceed to Checkout</a>
        <% } %>
    </div>
    <script src="/script.js"></script>
</body>
</html>
