<style> a{color:inherit} </style>
  <main class="auth-wrap">
    <div class="auth-card center">
      <div class="brand">
        <div class="logo">E</div>
        <div>
          <h2>Engine Shop</h2>
          <div style="color:var(--muted);font-size:0.95rem">Quality products, curated for you</div>
        </div>
      </div>

      <div class="form-header">
        <h1>Sign in</h1>
        <div class="form-sub">Welcome back — sign in to continue to the store.</div>
      </div>

      <% if (success && success.length) { %>
        <div class="flash-success"><%= success[0] %></div>
      <% } %>
      <% if (error && error.length) { %>
        <div class="flash-error"><%= error[0] %></div>
      <% } %>

      <form action="/login" method="POST">
        <div class="form-group">
          <label for="email">Email</label>
          <input id="email" class="form-control" type="email" name="email" required>
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input id="password" class="form-control" type="password" name="password" required>
        </div>
        <button class="btn-primary" type="submit">Sign In</button>
      </form>

      <div class="auth-footer" style="display:flex;justify-content:space-between;align-items:center;gap:12px;margin-top:18px">
        <div>Don't have an account? <a class="small-link" href="/register">Create one</a></div>
        <div><a class="small-link" href="/">Back to store</a></div>
      </div>
    </div>
  </main>
