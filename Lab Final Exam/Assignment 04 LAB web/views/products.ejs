<div class="products-page-wrapper">
    <!-- Sidebar Filter -->
    <aside class="products-sidebar-area">
        <h3>Filter</h3>
        <form action="/products" method="GET">
            <div class="sidebar-filter-item">
                <label>Search</label>
                <input type="text" name="search" placeholder="Search product..." value="<%= search %>">
            </div>

            <div class="sidebar-filter-item">
                <label>Category</label>
                <select name="category">
                    <option value="">All Categories</option>
                    <% allCategories.forEach(cat => { %>
                        <option value="<%= cat %>" <%= category === cat ? 'selected' : '' %>><%= cat %></option>
                    <% }) %>
                </select>
            </div>

            <div class="sidebar-filter-item">
                <label>Price Range</label>
                <div style="display:flex; gap:10px;">
                    <input type="number" name="minPrice" placeholder="Min" value="<%= minPrice %>">
                    <input type="number" name="maxPrice" placeholder="Max" value="<%= maxPrice %>">
                </div>
            </div>

            <div class="sidebar-filter-item">
                <label>Sort By</label>
                <select name="sort">
                    <option value="">Featured</option>
                    <option value="price_asc" <%= sort === 'price_asc' ? 'selected' : '' %>>Price: Low to High</option>
                    <option value="price_desc" <%= sort === 'price_desc' ? 'selected' : '' %>>Price: High to Low</option>
                    <option value="rating_desc" <%= sort === 'rating_desc' ? 'selected' : '' %>>Top Rated</option>
                </select>
            </div>

            <button type="submit" class="apply-sidebar-btn">Apply Filters</button>
            <a href="/products" style="display:block; text-align:center; margin-top:15px; color:#666; font-size:12px;">Clear All</a>
        </form>
    </aside>

    <!-- Main Products Grid -->
    <main class="products-main-area">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:30px;">
            <h1 style="margin:0; font-family:'Inter'; font-weight:800; text-transform:uppercase; font-size:24px;">Products</h1>
            <p style="margin:0; color:#666;"><%= totalProducts %> items found</p>
        </div>

        <div class="products-grid-layout">
            <% products.forEach(product => { %>
                <div class="premium-product-card">
                    <div class="image-container">
                        <img src="<%= product.image || '/1.avif' %>" alt="<%= product.name %>">
                        <span class="category-flag"><%= product.category %></span>
                        <button class="quick-add-plus" onclick="addToCart('<%= product._id %>')">+</button>
                    </div>
                    
                    <div class="product-meta-data">
                        <h4><%= product.name %></h4>
                        <div class="price-display">
                            <span class="new-price">PKR <%= product.price %></span>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>

        <!-- Pagination -->
        <div class="pagination" style="display:flex; justify-content:center; gap:10px; margin-top:50px;">
            <% const queryParams = `search=${encodeURIComponent(search)}&category=${encodeURIComponent(category)}&minPrice=${encodeURIComponent(minPrice)}&maxPrice=${encodeURIComponent(maxPrice)}&sort=${encodeURIComponent(sort)}`; %>
            
            <% if (currentPage > 1) { %>
                <a href="/products?page=<%= currentPage - 1 %>&<%= queryParams %>" style="padding:8px 16px; border:1px solid #ddd; text-decoration:none; color:#000;">Previous</a>
            <% } %>

            <% for (let i = 1; i <= totalPages; i++) { %>
                <a href="/products?page=<%= i %>&<%= queryParams %>" style="padding:8px 16px; border:1px solid #ddd; text-decoration:none; <%= i === currentPage ? 'background:#000; color:#fff;' : 'color:#000;' %>"><%= i %></a>
            <% } %>

            <% if (currentPage < totalPages) { %>
                <a href="/products?page=<%= currentPage + 1 %>&<%= queryParams %>" style="padding:8px 16px; border:1px solid #ddd; text-decoration:none; color:#000;">Next</a>
            <% } %>
        </div>
    </main>
</div>
