<%- include("./partials/header", { pageTitle: "Add Product", activePage: "add" }) %>

<div class="form-card">
    <% if (errors && errors.length) { %>
        <div class="error-box">
            <ul style="margin:0; padding-left:18px;">
                <% errors.forEach(error => { %>
                    <li><%= error %></li>
                <% }) %>
            </ul>
        </div>
    <% } %>

    <form class="form-grid" action="/admin/add" method="POST" enctype="multipart/form-data">
        <label for="name">Product Name</label>
        <input id="name" type="text" name="name" placeholder="Name" required value="<%= formData.name || '' %>">

        <label for="price">Price</label>
        <input id="price" type="number" name="price" placeholder="Price" required value="<%= formData.price || '' %>">

        <label for="category">Category</label>
        <select id="category" name="category" required>
            <option value="">Choose category</option>
            <% categories.forEach(cat => { %>
                <option value="<%= cat %>" <%= formData.category === cat ? 'selected' : '' %>><%= cat %></option>
            <% }) %>
        </select>

        <label for="rating">Rating</label>
        <input id="rating" type="number" name="rating" placeholder="Rating" step="0.1" value="<%= formData.rating || '' %>">

        <label for="stock">Stock</label>
        <input id="stock" type="number" name="stock" placeholder="Stock" required value="<%= formData.stock || '' %>">

        <label for="image">Product Image</label>
        <input id="image" type="file" name="image" accept="image/*">

        <button type="submit">Add Product</button>
    </form>
</div>

<%- include("./partials/footer") %>