<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Admin Account</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        .auth-tabs {
            display: flex;
            gap: 0;
            margin-bottom: 1.5rem;
            border-radius: 10px;
            overflow: hidden;
            border: 1.5px solid var(--border, #e5e7eb);
        }
        .auth-tab {
            flex: 1;
            padding: 0.6rem 1rem;
            text-align: center;
            font-size: 0.95rem;
            font-weight: 600;
            text-decoration: none;
            color: var(--muted, #6b7280);
            background: transparent;
            transition: background 0.2s, color 0.2s;
        }
        .auth-tab.active {
            background: #2563eb;
            color: #fff;
        }
        .auth-tab:hover:not(.active) {
            background: var(--hover, #f3f4f6);
            color: var(--text, #111);
        }
        .flash-success {
            background: #d1fae5;
            color: #065f46;
            border: 1px solid #a7f3d0;
            border-radius: 8px;
            padding: 0.65rem 1rem;
            margin-bottom: 1rem;
            font-size: 0.93rem;
        }
        .flash-error {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fca5a5;
            border-radius: 8px;
            padding: 0.65rem 1rem;
            margin-bottom: 1rem;
            font-size: 0.93rem;
        }
        .flash-error ul { margin: 0.3rem 0 0 1.2rem; padding: 0; }
        .flash-error li { margin-bottom: 0.2rem; }
    </style>
</head>
<body>
    <main class="auth-wrap">
        <div class="auth-card center">
            <div class="brand">
                <div class="logo">E</div>
                <div>
                    <h2>Engine Shop</h2>
                    <div style="color:var(--muted);font-size:0.95rem">Admin access area</div>
                </div>
            </div>

            <div class="auth-tabs">
                <a href="/admin/login" class="auth-tab">Sign In</a>
                <a href="/admin/register" class="auth-tab active">Create Account</a>
            </div>

            <div>
                <h1>Create <span style="color:#2563eb">Admin</span> Account</h1>

                <% if (success && success.length) { %>
                    <div class="flash-success"><%= success[0] %></div>
                <% } %>
                <% if (error && error.length) { %>
                    <div class="flash-error">
                        <% if (error.length === 1) { %>
                            <%= error[0] %>
                        <% } else { %>
                            <ul>
                                <% error.forEach(e => { %><li><%= e %></li><% }); %>
                            </ul>
                        <% } %>
                    </div>
                <% } %>

                <form action="/admin/register" method="POST">
                    <div class="form-group">
                        <label for="reg-name">Full Name</label>
                        <input id="reg-name" class="form-control" name="name" type="text"
                               value="<%= formData.name || '' %>" placeholder="John Doe" required>
                    </div>
                    <div class="form-group">
                        <label for="reg-email">Email</label>
                        <input id="reg-email" class="form-control" name="email" type="email"
                               value="<%= formData.email || '' %>" placeholder="admin@example.com" required>
                    </div>
                    <div class="form-group">
                        <label for="reg-password">Password</label>
                        <input id="reg-password" class="form-control" name="password" type="password"
                               placeholder="Min. 6 characters" required>
                    </div>
                    <div class="form-group">
                        <label for="reg-confirm">Confirm Password</label>
                        <input id="reg-confirm" class="form-control" name="confirmPassword" type="password"
                               placeholder="Repeat your password" required>
                    </div>
                    <button class="btn-primary" type="submit" style="width:100%;margin-top:0.5rem">
                        Create Admin Account
                    </button>
                </form>

                <p class="auth-footer" style="margin-top:1rem">
                    Already have an account? <a href="/admin/login" style="color:#2563eb;font-weight:600">Sign in</a>
                </p>
            </div>
        </div>
    </main>
</body>
</html>
