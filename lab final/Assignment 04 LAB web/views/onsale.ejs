<div class="products-page-wrapper">
    <!-- Sidebar Filter -->
    <aside class="products-sidebar-area">
        <h3>Filter Sale Items</h3>
        <form action="/onsale-products" method="GET">
            <div class="sidebar-filter-item">
                <label>Search</label>
                <input type="text" name="search" placeholder="Search product..." value="<%= typeof search !== 'undefined' ? search : '' %>">
            </div>

            <div class="sidebar-filter-item">
                <label>Category</label>
                <select name="category">
                    <option value="">All Categories</option>
                    <% if (typeof allCategories !== 'undefined') { %>
                        <% allCategories.forEach(cat => { %>
                            <option value="<%= cat %>" <%= (typeof category !== 'undefined' && category === cat) ? 'selected' : '' %>><%= cat %></option>
                        <% }) %>
                    <% } %>
                </select>
            </div>

            <div class="sidebar-filter-item">
                <label>Price Range</label>
                <div style="display:flex; gap:10px;">
                    <input type="number" name="minPrice" placeholder="Min" value="<%= typeof minPrice !== 'undefined' ? minPrice : '' %>">
                    <input type="number" name="maxPrice" placeholder="Max" value="<%= typeof maxPrice !== 'undefined' ? maxPrice : '' %>">
                </div>
            </div>

            <div class="sidebar-filter-item">
                <label>Sort By</label>
                <select name="sort">
                    <option value="">Featured</option>
                    <option value="price_asc" <%= (typeof sort !== 'undefined' && sort === 'price_asc') ? 'selected' : '' %>>Price: Low to High</option>
                    <option value="price_desc" <%= (typeof sort !== 'undefined' && sort === 'price_desc') ? 'selected' : '' %>>Price: High to Low</option>
                    <option value="rating_desc" <%= (typeof sort !== 'undefined' && sort === 'rating_desc') ? 'selected' : '' %>>Top Rated</option>
                </select>
            </div>

            <button type="submit" class="apply-sidebar-btn">Apply Filters</button>
            <a href="/onsale-products" style="display:block; text-align:center; margin-top:15px; color:#666; font-size:12px;">Clear All</a>
        </form>
    </aside>

    <main class="products-main-area">
        <!-- Hero banner -->
        <div class="onsale-hero">
            <div>
                <h1>🏷️ On-Sale Products</h1>
                <p>Exclusive deals — limited time only. Grab your favourites before they're gone!</p>
            </div>
            <div class="onsale-badge">
                <div class="count"><%= products.length %></div>
                <div class="label">Items on Sale</div>
            </div>
        </div>

        <% if (products.length === 0) { %>
            <div class="empty-state">
                <div class="emoji">🛒</div>
                <h2>No sale products matched your filter</h2>
                <p>Try adjusting your filters or search terms.</p>
            </div>
        <% } else { %>
            <div class="products-grid-layout" id="product-list">
                <% products.forEach(function(p) { %>
                    <article class="premium-product-card" data-id="<%= p._id %>">
                        <div class="image-container">
                            <span class="sale-badge">SALE</span>
                            <span class="discount-badge">50% OFF</span>
                            <img src="<%= p.image || '/1.avif' %>" alt="<%= p.name %>" loading="lazy">
                            <span class="category-flag"><%= p.category %></span>
                            <button class="quick-add-plus" onclick="addToCart('<%= p._id %>')">+</button>
                        </div>
                        <div class="product-meta-data">
                            <h4><%= p.name %></h4>
                            <div class="price-display">
                                <span class="new-price">Rs. <%= p.price %></span>
                                <span class="old-price">Rs. <%= (p.price * 2).toLocaleString() %></span>
                            </div>
                        </div>
                    </article>
                <% }); %>
            </div>

            <!-- ── Client-side Pagination controls ── -->
            <div class="pagination-controls">
                <button id="prev-btn" type="button">&#8592; Previous</button>
                <span   id="page-indicator">Page 1 of 1</span>
                <button id="next-btn" type="button">Next &#8594;</button>
            </div>
        <% } %>
    </main>
</div>

<style>
    /* ── Hero header ───────────────────────────────────────────── */
    .onsale-hero {
        background: linear-gradient(135deg, #b91c1c 0%, #7f1d1d 100%);
        border-radius: 20px;
        padding: 48px 40px;
        margin-bottom: 40px;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        box-shadow: 0 12px 40px rgba(185, 28, 28, .30);
    }
    .onsale-hero h1 {
        margin: 0 0 8px;
        font-size: 2.6rem;
        font-weight: 800;
        letter-spacing: -0.5px;
    }
    .onsale-hero p  {
        margin: 0;
        opacity: .85;
        font-size: 1.05rem;
    }
    .onsale-badge {
        background: rgba(255,255,255,.15);
        border: 2px solid rgba(255,255,255,.35);
        border-radius: 14px;
        padding: 18px 30px;
        text-align: center;
        flex-shrink: 0;
    }
    .onsale-badge .count { font-size: 2.8rem; font-weight: 800; line-height: 1; }
    .onsale-badge .label { font-size: .85rem; opacity: .85; margin-top: 4px; }

    /* ── Product card ──────────────────────────────────────────── */
    .premium-product-card {
        position: relative;
        display: flex;
        flex-direction: column;
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,.08);
        transition: transform .2s ease, box-shadow .2s ease;
    }
    .premium-product-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 28px rgba(0,0,0,.14);
    }
    .premium-product-card .image-container {
        position: relative;
        width: 100%;
        aspect-ratio: 3/4;
        overflow: hidden;
        background: #f3f4f6;
    }
    .premium-product-card .image-container img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform .35s ease;
    }
    .premium-product-card:hover .image-container img {
        transform: scale(1.05);
    }
    .product-meta-data {
        padding: 12px 14px 16px;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }
    .product-meta-data h4 {
        margin: 0;
        font-size: .95rem;
        font-weight: 600;
        color: #111827;
        line-height: 1.35;
    }
    .price-display {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }
    .new-price {
        font-size: 1rem;
        font-weight: 700;
        color: #b91c1c;
    }
    .old-price {
        font-size: .82rem;
        color: #9ca3af;
        text-decoration: line-through;
    }
    
    .sale-badge {
        position: absolute;
        top: 12px;
        left: 12px;
        background: #dc2626;
        color: #fff;
        font-size: .72rem;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 999px;
        letter-spacing: .06em;
        text-transform: uppercase;
        z-index: 2;
    }
    .discount-badge {
        position: absolute;
        top: 12px;
        right: 12px;
        background: #111827;
        color: #fff;
        font-size: .7rem;
        font-weight: 700;
        padding: 4px 9px;
        border-radius: 999px;
        z-index: 2;
    }

    /* ── Pagination controls ───────────────────────────────────── */
    .pagination-controls {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 20px;
        margin: 48px 0 20px;
    }
    .pagination-controls button {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 24px;
        border: none;
        border-radius: 12px;
        background: #111827;
        color: #fff;
        font-family: 'Inter', sans-serif;
        font-size: .95rem;
        font-weight: 600;
        cursor: pointer;
        transition: background .18s ease, transform .15s ease;
    }
    .pagination-controls button:hover:not(:disabled) {
        background: #1e3a8a;
        transform: translateY(-1px);
    }
    .pagination-controls button:disabled {
        background: #cbd5e1;
        color: #94a3b8;
        cursor: not-allowed;
        transform: none;
    }
    #page-indicator {
        min-width: 120px;
        text-align: center;
        font-weight: 700;
        font-size: 1rem;
        color: #0f172a;
        background: #f1f5f9;
        padding: 10px 18px;
        border-radius: 10px;
    }

    /* ── Empty state ───────────────────────────────────────────── */
    .empty-state {
        text-align: center;
        padding: 80px 20px;
        background: #f8fafc;
        border-radius: 16px;
        color: #64748b;
    }
    .empty-state .emoji { font-size: 3rem; margin-bottom: 12px; }
    .empty-state h2 { margin: 0 0 8px; color: #0f172a; }
</style>

<script>
/**
 * On-Sale Products — jQuery Pagination
 */
$(function () {
    var PER_PAGE   = 10;
    var $cards     = $('#product-list .premium-product-card');
    var total      = $cards.length;
    var totalPages = Math.max(1, Math.ceil(total / PER_PAGE));
    var currentPage = 1;

    var $prev      = $('#prev-btn');
    var $next      = $('#next-btn');
    var $indicator = $('#page-indicator');

    function render() {
        $cards.hide();
        var start = (currentPage - 1) * PER_PAGE;
        var end   = start + PER_PAGE;
        $cards.slice(start, end).css({ "display": "flex", "flex-direction": "column" });

        $indicator.text('Page ' + currentPage + ' of ' + totalPages);
        $prev.prop('disabled', currentPage === 1);
        $next.prop('disabled', currentPage === totalPages);
    }

    $next.on('click', function () {
        if (currentPage < totalPages) {
            currentPage++;
            render();
            $('html, body').animate({ scrollTop: $('.products-main-area').offset().top - 90 }, 300);
        }
    });

    $prev.on('click', function () {
        if (currentPage > 1) {
            currentPage--;
            render();
            $('html, body').animate({ scrollTop: $('.products-main-area').offset().top - 90 }, 300);
        }
    });

    render();
});
</script>
