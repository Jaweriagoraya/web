<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %> | Admin Panel</title>
    <style>
        body { margin: 0; font-family: Arial, sans-serif; background: #f4f6f8; color: #111827; }
        .admin-shell { display: flex; min-height: 100vh; }
        .admin-sidebar { width: 240px; background: #111827; color: #e2e8f0; padding: 24px 16px; box-sizing: border-box; position: sticky; top: 0; height: fit-content; align-self: flex-start; z-index: 20; }
        .admin-sidebar h2 { margin-top: 0; margin-bottom: 1.5rem; font-size: 1.4rem; letter-spacing: 0.03em; }
        .admin-sidebar a { display: block; color: #cbd5e1; text-decoration: none; margin: 10px 0; padding: 10px 14px; border-radius: 10px; }
        .admin-sidebar a.active, .admin-sidebar a:hover { background: #1f2937; color: #fff; }
        .admin-main { flex: 1; padding: 24px 32px; }
        .admin-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; gap: 16px; position: sticky; top: 0; background: #f4f6f8; z-index: 15; padding-top: 24px; padding-bottom: 18px; }
        .admin-header h1 { margin: 0; font-size: 2rem; }
        .admin-actions a.button { display: inline-flex; align-items: center; justify-content: center; background: #2563eb; color: #fff; padding: 11px 18px; border-radius: 10px; text-decoration: none; font-weight: 600; }
        .summary { margin-bottom: 24px; display: flex; flex-wrap: wrap; gap: 16px; }
        .summary-card { background: #fff; padding: 18px 22px; border-radius: 16px; box-shadow: 0 14px 30px rgba(15,23,42,.08); min-width: 180px; }
        .summary-card span { display: block; color: #64748b; margin-bottom: 8px; }
        .summary-card strong { font-size: 1.8rem; color: #111827; }
        .table { width: 100%; border-collapse: collapse; background: #fff; border-radius: 16px; overflow: hidden; box-shadow: 0 14px 35px rgba(15,23,42,.08); }
        .table th, .table td { padding: 16px 18px; text-align: left; border-bottom: 1px solid #e2e8f0; }
        .table th { background: #f8fafc; color: #0f172a; font-weight: 700; }
        .table tr:last-child td { border-bottom: none; }
        .button { display: inline-flex; align-items: center; justify-content: center; padding: 10px 16px; border-radius: 10px; border: none; color: #fff; text-decoration: none; font-size: 0.95rem; cursor: pointer; }
        .button.edit { background: #16a34a; }
        .button.delete { background: #ef4444; }
        .button.secondary { background: #475569; }
        .form-card { background: #fff; padding: 26px; border-radius: 18px; box-shadow: 0 14px 30px rgba(15,23,42,.08); max-width: 760px; }
        .form-grid { display: grid; gap: 16px; }
        .form-grid label { font-weight: 600; color: #334155; }
        .form-grid input, .form-grid select, .form-grid button { width: 100%; padding: 14px 16px; border: 1px solid #cbd5e1; border-radius: 12px; font-size: 1rem; }
        .form-grid input:focus, .form-grid select:focus { outline: none; border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,0.12); }
        .form-grid button { border: none; background: #2563eb; color: #fff; font-weight: 700; cursor: pointer; }
        .product-thumb { width: 80px; height: 80px; object-fit: cover; border-radius: 12px; }
        .error-box { background: #fee2e2; color: #991b1b; padding: 14px 16px; border-radius: 12px; margin-bottom: 20px; }
        .top-bar { display:flex; justify-content:space-between; flex-wrap:wrap; gap:12px; margin-bottom:14px; }
        .top-bar .logout { background: #ef4444; }

        @media (max-width: 850px) {
            .admin-shell { flex-direction: column; }
            .admin-sidebar { width: 100%; padding: 15px; display: flex; overflow-x: auto; gap: 10px; }
            .admin-sidebar h2 { display: none; }
            .admin-sidebar a { margin: 0; white-space: nowrap; padding: 8px 12px; font-size: 14px; }
            .admin-main { padding: 15px; }
            .admin-header { flex-direction: column; align-items: flex-start; }
            .summary { gap: 10px; }
            .summary-card { flex: 1; min-width: 140px; padding: 15px; }
            .table { display: block; overflow-x: auto; }
            .product-thumb { width: 50px; height: 50px; }
        }
    </style>
</head>
<body>
<div class="admin-shell">
    <aside class="admin-sidebar">
        <h2>Admin Panel</h2>
        <a href="/admin" class="<%= activePage === 'dashboard' ? 'active' : '' %>">Dashboard</a>
        <a href="/admin/add" class="<%= activePage === 'add' ? 'active' : '' %>">Add Product</a>
        <a href="/" class="<%= activePage === 'home' ? 'active' : '' %>">Store Home</a>
        <a href="/admin/logout" class="<%= activePage === 'logout' ? 'active' : '' %>">Logout</a>
    </aside>
    <main class="admin-main">
        <div class="admin-header">
            <div>
                <h1><%= pageTitle %></h1>
                <% if (typeof subtitle !== 'undefined' && subtitle) { %><p style="color:#64748b; margin:6px 0 0;"><%= subtitle %></p><% } %>
            </div>
            <div class="admin-actions">
                <a href="/admin/add" class="button secondary">New Product</a>
                <a href="/admin/logout" class="button logout">Logout</a>
            </div>
        </div>
