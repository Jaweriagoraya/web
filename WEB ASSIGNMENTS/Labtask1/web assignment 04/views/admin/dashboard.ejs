<%- include("./partials/header", { pageTitle: "Dashboard", activePage: "dashboard", subtitle: "Manage your product inventory and monitor stock" }) %>

<div class="summary">
    <div class="summary-card">
        <span>Total Products</span>
        <strong><%= products.length %></strong>
    </div>
    <div class="summary-card">
        <span>Categories</span>
        <strong><%= [...new Set(products.map(p => p.category))].length %></strong>
    </div>
</div>

<table class="table">
    <thead>
        <tr>
            <th>Image</th>
            <th>Name</th>
            <th>Price</th>
            <th>Stock</th>
            <th>Category</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        <% if (products.length === 0) { %>
            <tr>
                <td colspan="6" style="text-align:center; padding: 24px;">No products available. Add a new product to get started.</td>
            </tr>
        <% } %>
        <% products.forEach(product => { %>
            <tr>
                <td><img src="<%= product.image %>" alt="<%= product.name %>" class="product-thumb"></td>
                <td><%= product.name %></td>
                <td>₹<%= product.price %></td>
                <td><%= product.stock %></td>
                <td><%= product.category %></td>
                <td>
                    <a href="/admin/edit/<%= product._id %>" class="button edit">Edit</a>
                    <form action="/admin/delete/<%= product._id %>?_method=DELETE" method="POST" style="display:inline; margin-left: 10px;" onsubmit="return confirmDelete(this);">
                        <button type="submit" class="button delete">Delete</button>
                    </form>
                </td>
            </tr>
        <% }) %>
    </tbody>
</table>

<%- include("./partials/footer") %>